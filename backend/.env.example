# --- LLM ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- MySQL (use service names from docker-compose) ---
APP_DATABASE_URL=mysql+aiomysql://dashboard_app:app_pw@mysql:3306/school_db
READONLY_DATABASE_URL=mysql+aiomysql://nl2sql_reader:reader_pw@mysql:3306/school_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Langfuse (optional) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- NL2SQL allow-list (defense-in-depth on top of read-only user) ---
ALLOWED_TABLES=students,teachers,classes,attendance,assessments,assignments,fees,behavior_notes,student_summary,alerts,digests,chat_logs

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
